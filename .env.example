#-----------------------------------------------------------------------
# Application Configuration
#-----------------------------------------------------------------------
# APP_NAME: Nama aplikasi yang ditampilkan di title bar dan header
APP_NAME="CMS Landing"

# APP_ENV: Environment aplikasi (local, staging, production)
APP_ENV=local

# APP_KEY: Encryption key — generate dengan `php artisan key:generate`
APP_KEY=

# APP_DEBUG: Aktifkan debug mode (true untuk development, false untuk production)
APP_DEBUG=true

# APP_TIMEZONE: Timezone default aplikasi
APP_TIMEZONE=Asia/Jakarta

# APP_URL: URL dasar aplikasi
APP_URL=http://localhost:8000

# APP_LOCALE: Bahasa default aplikasi
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# APP_MAINTENANCE_DRIVER: Driver untuk maintenance mode (file atau database)
APP_MAINTENANCE_DRIVER=file

#-----------------------------------------------------------------------
# Logging Configuration
#-----------------------------------------------------------------------
# LOG_CHANNEL: Channel logging (stack, single, daily, stderr)
LOG_CHANNEL=stack

# LOG_STACK: Stack channels yang digunakan
LOG_STACK=single

# LOG_LEVEL: Level minimum log yang dicatat (debug, info, notice, warning, error)
LOG_LEVEL=debug

#-----------------------------------------------------------------------
# Database Configuration
#-----------------------------------------------------------------------
# DB_CONNECTION: Driver database (mysql, pgsql, sqlite)
DB_CONNECTION=mysql

# DB_HOST: Hostname database
DB_HOST=127.0.0.1

# DB_PORT: Port database
DB_PORT=3306

# DB_DATABASE: Nama database
DB_DATABASE=cms_landing

# DB_USERNAME: Username database
DB_USERNAME=root

# DB_PASSWORD: Password database (kosong untuk Laragon default)
DB_PASSWORD=

#-----------------------------------------------------------------------
# Session Configuration
#-----------------------------------------------------------------------
# SESSION_DRIVER: Driver session (file, database, redis, cookie)
SESSION_DRIVER=file

# SESSION_LIFETIME: Durasi session dalam menit
SESSION_LIFETIME=120

# SESSION_ENCRYPT: Enkripsi data session (true/false)
SESSION_ENCRYPT=false

#-----------------------------------------------------------------------
# Cache & Queue Configuration
#-----------------------------------------------------------------------
# CACHE_STORE: Driver cache (file, database, redis, memcached)
CACHE_STORE=file

# QUEUE_CONNECTION: Driver queue (sync, database, redis)
QUEUE_CONNECTION=sync

#-----------------------------------------------------------------------
# Filesystem Configuration
#-----------------------------------------------------------------------
# FILESYSTEM_DISK: Disk default untuk file storage (local, public, s3)
FILESYSTEM_DISK=local

#-----------------------------------------------------------------------
# Mail Configuration (opsional)
#-----------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

#-----------------------------------------------------------------------
# Vite Configuration
#-----------------------------------------------------------------------
# VITE_APP_NAME: Nama aplikasi yang diakses di frontend
VITE_APP_NAME="${APP_NAME}"
